# 复制本文件为 secrets.toml（已 gitignore），填入真实 key 后即可运行。
# 论文构思者 / paper-muse 默认栈：DeepSeek 主力 LLM + Tavily 检索 + 阿里云百炼 embedding。

# ============ language model configurations ============
# OpenAI（备用 LLM；run_storm_wiki_gpt.py 用 chat-latest）— https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-YOUR_OPENAI_KEY"
OPENAI_API_TYPE="openai"

# DeepSeek（主力 LLM；命令行/前端默认，v4-flash 便宜步骤 + v4-pro 强步骤）— https://platform.deepseek.com
DEEPSEEK_API_KEY="sk-YOUR_DEEPSEEK_KEY"
DEEPSEEK_API_BASE="https://api.deepseek.com"

# Gemini（备用 LLM；run_storm_wiki_gemini.py 用 gemini-3.1-flash-lite，非 thinking）— https://ai.google.dev
GOOGLE_API_KEY="AIzaSy-YOUR_GEMINI_KEY"

# ============ retriever configurations ============
# Tavily 检索 — https://app.tavily.com
TAVILY_API_KEY="tvly-dev-YOUR_TAVILY_KEY"

# Perplexity Search API（多源检索可选源）— https://docs.perplexity.ai
PERPLEXITY_API_KEY="pplx-YOUR_PERPLEXITY_KEY"

# Jina Reader（检索结果全文增强，可选）— https://jina.ai/reader
JINA_API_KEY="jina_YOUR_JINA_KEY"

# ============ encoder (embedding) configurations ============
# 阿里云百炼 text-embedding-v4（OpenAI 兼容端点）— https://bailian.console.aliyun.com
# 不想用百炼就删掉下面 ENCODER_MODEL/KEY/BASE 三行，自动回退 OpenAI text-embedding-3-small
ENCODER_API_TYPE="openai"
ENCODER_MODEL="openai/text-embedding-v4"
ENCODER_API_KEY="sk-YOUR_DASHSCOPE_KEY"
ENCODER_API_BASE="https://dashscope.aliyuncs.com/compatible-mode/v1"

# ============ optional self-library evidence QA (PaperQA2) ============
# PaperQA2 独立装到 .venv-paperqa（见 requirements-paperqa.txt），避免污染主运行时。
# PAPER_MUSE_PDF_DIR 指向 Zotero 导出的 PDF 目录；PQA_HOME 可改 PaperQA 索引缓存目录。
PAPER_MUSE_PAPERQA_LLM="gemini/gemini-2.0-flash"
PAPER_MUSE_PAPERQA_EMBEDDING="gemini/text-embedding-004"
PAPER_MUSE_PDF_DIR="/path/to/zotero/pdf/export"
# PQA_HOME="/path/to/paperqa/cache"
